      <TextField fx:id="txtUsuario" maxWidth="250.0" prefWidth="250.0" />
      <Label text="🔒 Contraseña" />
      <PasswordField fx:id="txtContraseña" maxWidth="250.0" prefWidth="250.0" />
      <Label text="Rol" />
      <ComboBox fx:id="cmbRol" maxWidth="250.0" prefWidth="250.0" promptText="Seleccione un rol" />
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="15.0">
         <children>
            <Button fx:id="btnIngresar" mnemonicParsing="false" onAction="#ingresar" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 8;" text="Ingresar" />
            <Button fx:id="btnSalir" mnemonicParsing="false" onAction="#salir" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 8;" text="Salir" />
